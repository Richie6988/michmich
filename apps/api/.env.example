# ============================================================
# Barry API — environment example
# Copy this to apps/api/.env (or rely on root .env) and adjust.
# ============================================================

# --- Database ---
# Either DATABASE_URL or PGHOST/PGPORT/etc.
# Portable Windows dev defaults to localhost:5433
DATABASE_URL=postgres://barry:barry_dev@localhost:5433/barry

# --- Server ---
PORT=3001
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# --- JWT ---
# Generate a real secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=dev-secret-change-me-please
JWT_EXPIRES_IN=30d

# --- Equity engine (Python service) ---
EQUITY_ENGINE_URL=http://localhost:8000

# --- Redis (BullMQ for background jobs) ---
REDIS_HOST=localhost
REDIS_PORT=6380

# --- Web Push (VAPID) ---
# Generate: npx web-push generate-vapid-keys
# VAPID_PUBLIC=
# VAPID_PRIVATE=
# VAPID_SUBJECT=mailto:hello@barry.app

# --- Stripe (production payments) ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# --- Object storage (photos in production - S3 compatible) ---
# S3_ENDPOINT=
# S3_BUCKET=barry-photos
# S3_KEY=
# S3_SECRET=
