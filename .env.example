# ============================================================
# BARRY — Environment Variables
# Copy to .env and fill in your values
# ============================================================

# --- Database (PostgreSQL + PostGIS) ---
POSTGRES_USER=barry
POSTGRES_PASSWORD=barry_dev_2026
POSTGRES_DB=barry
DATABASE_URL=postgresql://barry:barry_dev_2026@localhost:5432/barry

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- JWT ---
JWT_SECRET=barry-dev-secret-change-in-production-please
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# --- OSRM (self-hosted routing) ---
OSRM_URL=http://localhost:5000

# --- Equity Engine ---
EQUITY_ENGINE_URL=http://localhost:8000
EQUITY_GRID_RESOLUTION=20
EQUITY_MAX_RADIUS_KM=50

# --- Mapbox ---
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token_here
EXPO_PUBLIC_MAPBOX_TOKEN=your_mapbox_token_here

# --- App URLs ---
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
EXPO_PUBLIC_API_URL=http://localhost:3001

# --- OAuth2 (Phase 3B) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# APPLE_CLIENT_ID=
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=

# --- Stripe (Phase 3B) ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# --- External APIs (Phase 3B) ---
# NAVITIA_TOKEN=
# SNCF_API_KEY=
# THEFORK_API_KEY=
# BOOKING_COM_AFFILIATE_ID=

# --- Environment ---
NODE_ENV=development
